# Matchpoint(寻星) V1 runtime configuration

# The port that the Nest server listens on.
PORT=3000

# JWT signing secret for login tokens.
JWT_SECRET=change-me-to-a-long-random-string

# Optional. Defaults to 7d when omitted.
JWT_EXPIRES_IN=7d

# PostgreSQL connection string for Prisma.
# Example:
# postgresql://postgres:password@localhost:5432/matchpoint?schema=public
PRISMA_DATABASE_URL=postgresql://postgres:password@localhost:5432/matchpoint?schema=public

# Optional. Comma-separated list of allowed origins.
# When running the bundled web page from the same Nest service, this can stay on localhost.
CORS_ORIGINS=http://localhost:3000

AI_API_BASE_URL = http://127.0.0.1:1234/v1
AI_MODEL = qwen/qwen3-4b
AI_API_KEY=lm-studio