{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      "resources/**/*",
      {
        "include": "**/*.json",
        "watchAssets": false,
        "outDir": "./dist"
      }
    ],
    "watchAssets": true
  }
}