{
  "name": "matchpoint-backend",
  "version": "1.0.0",
  "description": "Matchpoint(寻星) V1 backend",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build-prisma": "prisma-import -s \"src/**/*.prisma\" -o prisma/schema.prisma --force && prisma-case-format --file prisma/schema.prisma && prisma generate",
    "postinstall": "prisma-import -s \"src/**/*.prisma\" -o prisma/schema.prisma --force && prisma-case-format --file prisma/schema.prisma && prisma generate",
    "prisma:push": "prisma db push",
    "build": "nest build",
    "status:dev": "node scripts/dev-server.js status",
    "stop:dev": "node scripts/dev-server.js stop",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:clean": "node scripts/dev-server.js start-clean",
    "start:prod": "node dist/main"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/serve-static": "^4.0.2",
    "@prisma/client": "6.4.1",
    "axios": "^1.10.0",
    "bcryptjs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.14.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.5",
    "@types/node": "^22.13.14",
    "prisma": "6.4.1",
    "prisma-case-format": "^2.2.1",
    "prisma-import": "^1.0.5",
    "prisma-json-types-generator": "^3.0.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af"
}